generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  passwordHash       String              @map("password_hash")
  firstName          String              @map("first_name")
  lastName           String              @map("last_name")
  phone              String?             @unique
  role               UserRole            @default(CLIENT)
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime?           @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")
  enabled            Boolean             @default(true)
  countryId          String?             @map("country_id")
  auditLogs          AuditLog[]
  devices            Device[]
  forumComments      ForumComment[]
  forumFavorites     ForumFavorite[]
  forumLikes         ForumLike[]
  forumPosts         ForumPost[]
  notifications      Notification[]
  profile            Profile?
  publications       Publication[]
  sessions           Session[]
  supportAssignments SupportAssignment[]
  chatMessages       ChatMessage[]
  country            Country?            @relation("UserCountryPreference", fields: [countryId], references: [id])
  workshop           Workshop?

  @@map("users")
}

model AuditLog {
  id        String    @id @default(uuid())
  action    String
  details   Json?
  userId    String    @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model Profile {
  id        String    @id @default(uuid())
  avatarUrl String?   @map("avatar_url")
  userId    String    @unique @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Session {
  id        String    @id @default(uuid())
  token     String    @unique
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  expiresAt DateTime  @map("expires_at")
  userId    String    @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Device {
  id        String    @id @default(uuid())
  deviceId  String    @unique @map("device_id")
  fcmToken  String?   @map("fcm_token")
  userId    String    @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("devices")
}

model Notification {
  id        String    @id @default(uuid())
  title     String
  content   String
  isRead    Boolean   @default(false) @map("is_read")
  userId    String    @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Country {
  id                 String              @id @default(uuid())
  name               String              @unique
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime?           @updatedAt @map("updated_at")
  enabled            Boolean             @default(false)
  deletedAt          DateTime?           @map("deleted_at")
  flag               String?
  currencyId         String?             @map("currency_id")
  timezone           String?
  latitude           Float?
  longitude          Float?
  language           String?
  slug               String?             @unique
  primaryColor       String?             @map("primary_color")
  secondaryColor     String?             @map("secondary_color")
  tertiaryColor      String?             @map("tertiary_color")
  cities             City[]
  supportAssignments SupportAssignment[]
  users              User[]              @relation("UserCountryPreference")
  workshops          Workshop[]

  @@map("countries")
}

model City {
  id                 String              @id @default(uuid())
  name               String
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime?           @updatedAt @map("updated_at")
  countryId          String              @map("country_id")
  enabled            Boolean             @default(true)
  deletedAt          DateTime?           @map("deleted_at")
  slug               String?
  country            Country             @relation(fields: [countryId], references: [id])
  supportAssignments SupportAssignment[]
  workshops          Workshop[]

  @@unique([name, countryId])
  @@unique([slug, countryId])
  @@map("cities")
}

model SupportAssignment {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  countryId String?   @map("country_id")
  cityId    String?   @map("city_id")
  deletedAt DateTime? @map("deleted_at")
  city      City?     @relation(fields: [cityId], references: [id])
  country   Country?  @relation(fields: [countryId], references: [id])
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("support_assignments")
}

model WorkshopCategory {
  id                 String               @id @default(uuid())
  name               String               @unique
  description        String?
  enabled            Boolean              @default(true)
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime?            @updatedAt @map("updated_at")
  deletedAt          DateTime?            @map("deleted_at")
  WorkshopToCategory WorkshopToCategory[]
  forumPosts         ForumPost[]          @relation("ForumToCategory")
  publications       Publication[]        @relation("PublicationToCategory")

  @@map("workshop_categories")
}

model Workshop {
  id                 String               @id @default(uuid())
  name               String
  description        String?
  address            String
  phone              String?
  whatsapp           String?
  website            String?
  latitude           Float?
  longitude          Float?
  logoUrl            String?              @map("logo_url")
  images             String[]
  enabled            Boolean              @default(true)
  openingHours       String?              @map("opening_hours")
  socialMedia        Json?                @map("social_media")
  userId             String               @unique @map("user_id")
  countryId          String               @map("country_id")
  cityId             String               @map("city_id")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime?            @updatedAt @map("updated_at")
  deletedAt          DateTime?            @map("deleted_at")
  slug               String?              @unique
  WorkshopToCategory WorkshopToCategory[]
  forumPosts         ForumPost[]
  publications       Publication[]
  city               City                 @relation(fields: [cityId], references: [id])
  country            Country              @relation(fields: [countryId], references: [id])
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("workshops")
}

model Publication {
  id         String             @id @default(uuid())
  workshopId String?            @map("workshop_id")
  title      String
  content    String
  images     String[]
  enabled    Boolean            @default(true)
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime?          @updatedAt @map("updated_at")
  deletedAt  DateTime?          @map("deleted_at")
  userId     String             @map("user_id")
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  workshop   Workshop?          @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  categories WorkshopCategory[] @relation("PublicationToCategory")

  @@map("publications")
}

model ForumPost {
  id         String             @id @default(uuid())
  title      String
  content    String
  images     String[]
  enabled    Boolean            @default(false)
  userId     String             @map("user_id")
  workshopId String?            @map("workshop_id")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime?          @updatedAt @map("updated_at")
  deletedAt  DateTime?          @map("deleted_at")
  comments   ForumComment[]
  favorites  ForumFavorite[]
  likes      ForumLike[]
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  workshop   Workshop?          @relation(fields: [workshopId], references: [id])
  categories WorkshopCategory[] @relation("ForumToCategory")

  @@map("forum_posts")
}

model ForumComment {
  id        String    @id @default(uuid())
  content   String
  rating    Int       @default(0)
  enabled   Boolean   @default(true)
  postId    String    @map("post_id")
  userId    String    @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("forum_comments")
}

model ForumLike {
  userId    String    @map("user_id")
  postId    String    @map("post_id")
  deletedAt DateTime? @map("deleted_at")
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@map("forum_likes")
}

model ForumFavorite {
  userId    String    @map("user_id")
  postId    String    @map("post_id")
  deletedAt DateTime? @map("deleted_at")
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@map("forum_favorites")
}

model WorkshopToCategory {
  A                   String
  B                   String
  workshops           Workshop         @relation(fields: [A], references: [id], onDelete: Cascade)
  workshop_categories WorkshopCategory @relation(fields: [B], references: [id], onDelete: Cascade)

  @@id([A, B], map: "_WorkshopToCategory_AB_pkey")
  @@index([B], map: "_WorkshopToCategory_B_index")
  @@map("_WorkshopToCategory")
}

model ChatMessage {
  id        String   @id @default(uuid())
  content   String
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("chat_messages")
}

enum UserRole {
  ADMIN
  SUPPORT
  TALLER
  CLIENT
}
